# ══════════════════════════════════════════════════════════════════
# Ritmo App Environment Variables — Template
# ══════════════════════════════════════════════════════════════════
# Copy to .env.local and fill in actual values.
# Expo SDK 54: EXPO_PUBLIC_ prefix → process.env.EXPO_PUBLIC_XXX

# ── Analysis Server ──────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=https://api.ritmo.kr

# ── Supabase (BaaS) ─────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── EAS (Expo Application Services) ─────────────────────────────
EXPO_PUBLIC_EAS_PROJECT_ID=
