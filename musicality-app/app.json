{
  "expo": {
    "name": "Ritmo",
    "slug": "musicality-app",
    "version": "0.9.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "musicality",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "kr.ritmo.musicality",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSPhotoLibraryUsageDescription": "Used to select profile photos and crew images"
      },
      "privacyUrl": "https://ritmo.kr/privacy.html"
    },
    "android": {
      "package": "com.ongocompany.musicality",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "READ_EXTERNAL_STORAGE",
        "SYSTEM_ALERT_WINDOW",
        "VIBRATE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-web-browser",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1d7a456-edab-43d8-adbe-9ce0c1fb04a3"
      }
    },
    "owner": "ongocampany",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e1d7a456-edab-43d8-adbe-9ce0c1fb04a3"
    }
  }
}
